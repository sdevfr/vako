{
  "name": "vako",
  "version": "1.3.21",
  "description": "🚀 Ultra-modern Node.js framework with hot reload, plugins, authentication, TypeScript support, and Next.js integration",
  "main": "index.js",
  "types": "types/index.d.ts",
  "bin": {
    "vako": "./bin/vako.js",
    "create-vako-app": "./bin/create-vako-app.js",
    "vako-update": "./bin/vako-update.js"
  },
  "scripts": {
    "dev": "node bin/vako.js dev",
    "build": "node bin/vako.js build",
    "start": "node bin/vako.js start",
    "test": "jest --coverage --passWithNoTests",
    "test:watch": "jest --watch",
    "test:security": "npm audit && node scripts/security-check.js",
    "lint": "eslint lib/ bin/ --fix",
    "lint:check": "eslint lib/ bin/",
    "prepare": "husky",
    "prepublishOnly": "npm test && npm run lint:check",
    "create-app": "node bin/create-vako-app.js",
    "docs": "jsdoc lib/ -d docs/",
    "benchmark": "node scripts/benchmark.js",
    "verify": "node verify-code.js"
  },
  "keywords": [
    "framework",
    "express",
    "ejs",
    "hot-reload",
    "plugins",
    "websocket",
    "dev-server",
    "auto-refresh",
    "file-watcher",
    "authentication",
    "security",
    "performance",
    "modern",
    "typescript",
    "nextjs",
    "next.js",
    "adapter",
    "cors",
    "helmet",
    "rate-limiting",
    "validation",
    "layout-engine",
    "plugin-system"
  ],
  "author": "Wiltark <contact@wiltark.fr>",
  "license": "MIT",
  "homepage": "https://vako.js.org",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sdevfr/vako.git"
  },
  "bugs": {
    "url": "https://github.com/l0wkn1ght/vako/issues"
  },
  "dependencies": {
    "archiver": "^6.0.1",
    "async": "^3.2.5",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.3",
    "boxen": "^5.1.2",
    "chalk": "^4.1.2",
    "chokidar": "^3.5.3",
    "clean-css": "^5.3.2",
    "commander": "^11.1.0",
    "compression": "^1.7.4",
    "connect-redis": "^7.1.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "debug": "^4.3.4",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "express-useragent": "^1.0.15",
    "express-validator": "^7.0.1",
    "figlet": "^1.6.0",
    "fs-extra": "^11.2.0",
    "geoip-lite": "^2.0.3",
    "gradient-string": "^2.0.2",
    "helmet": "^7.1.0",
    "html-minifier-terser": "^7.2.0",
    "inquirer": "^8.2.6",
    "jimp": "^1.6.1",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "mime-types": "^2.1.35",
    "moment": "^2.29.4",
    "mongoose": "^8.0.3",
    "multer": "^2.0.0",
    "mysql2": "^3.6.5",
    "nanospinner": "^1.1.0",
    "node-cron": "^4.5.0",
    "nodemailer": "^9.0.3",
    "ora": "^5.4.1",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "passport-local": "^1.0.0",
    "pg": "^8.11.3",
    "redis": "^4.6.10",
    "semver": "^7.5.4",
    "sequelize": "^6.37.8",
    "sharp": "^0.33.5",
    "slugify": "^1.6.6",
    "sqlite3": "^6.0.1",
    "uglify-js": "^3.17.4",
    "uuid": "^14.0.1",
    "validator": "^13.11.0",
    "winston": "^3.11.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.1",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.5",
    "cross-env": "^7.0.3",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-html": "^8.1.4",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.1.1",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "jsdoc": "^4.0.2",
    "lint-staged": "^15.2.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "optionalDependencies": {
    "pm2": "^7.0.3"
  },
  "peerDependencies": {
    "typescript": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "files": [
    "lib/",
    "bin/",
    "views/",
    "error/",
    "templates/",
    "types/",
    "index.js",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "tsconfig.json"
  ],
  "preferGlobal": true,
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "lib/**/*.js",
      "!lib/**/*.test.js",
      "!lib/**/node_modules/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "standard"
    ],
    "env": {
      "node": true,
      "jest": true,
      "es2022": true,
      "browser": true
    },
    "globals": {
      "setTimeout": "readonly",
      "clearTimeout": "readonly",
      "setInterval": "readonly",
      "clearInterval": "readonly",
      "Buffer": "readonly",
      "global": "readonly"
    },
    "rules": {
      "no-console": "warn",
      "prefer-const": "error",
      "no-var": "error",
      "no-control-regex": "off",
      "no-useless-escape": "off",
      "no-empty": "off",
      "no-unused-vars": "warn"
    }
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "npm test"
    }
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/wiltark"
  },
  "contributors": [
    {
      "name": "Wiltark",
      "email": "contact@wiltark.fr",
      "url": "https://wiltark.fr"
    }
  ],
  "allowScripts": {
    "sharp@0.33.5": true,
    "sqlite3@6.0.1": true
  }
}
